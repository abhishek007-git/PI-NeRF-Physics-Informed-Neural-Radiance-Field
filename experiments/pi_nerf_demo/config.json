{
  "experiment": {
    "name": "pi_nerf_cpu_dev",
    "seed": 42,
    "output_dir": "experiments"
  },
  "model": {
    "pos_enc_levels": 6,
    "dir_enc_levels": 4,
    "use_hash_encoding": false,
    "net_depth": 4,
    "net_width": 128,
    "skip_connect": [
      2
    ],
    "use_viewdirs": true,
    "use_fine_network": true,
    "fine_net_depth": 4,
    "fine_net_width": 128
  },
  "renderer": {
    "near": 2.0,
    "far": 6.0,
    "n_coarse": 16,
    "n_fine": 32,
    "perturb": true,
    "white_background": true
  },
  "physics": {
    "use_eikonal": true,
    "use_laplacian": true,
    "lambda_eikonal": 0.001,
    "lambda_laplacian": 1e-06,
    "n_physics_samples": 32,
    "physics_warmup_steps": 100
  },
  "training": {
    "n_iterations": 300,
    "batch_size": 128,
    "lr_init": 0.0005,
    "lr_final": 5e-06,
    "lr_decay_steps": 5000,
    "warmup_steps": 100,
    "log_every": 50,
    "save_every": 300,
    "val_every": 300,
    "chunk_size": 256
  },
  "evaluation": {
    "metrics": [
      "psnr",
      "ssim"
    ],
    "n_test_views": 10
  },
  "data": {
    "dataset_type": "synthetic",
    "scene": "sphere",
    "data_dir": "data/synthetic",
    "half_res": true,
    "white_background": true,
    "image_width": 32,
    "image_height": 32,
    "n_train_views": 20,
    "n_test_views": 5
  }
}